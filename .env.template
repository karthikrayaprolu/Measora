DATABASE_URL="postgresql://postgres.[PROJECT-REF]:[PASSWORD]@aws-0-eu-central-1.pooler.supabase.com:6543/postgres"

# Frontend / Supabase Auth Connection
VITE_SUPABASE_URL="https://[PROJECT-REF].supabase.co"
VITE_SUPABASE_ANON_KEY="your-anon-key-here"
SUPABASE_URL="https://[PROJECT-REF].supabase.co"
SUPABASE_ANON_KEY="your-anon-key-here"

# Backend Auth Verification
SECRET_KEY="your-supabase-jwt-secret-here"
ALGORITHM="HS256"

# CORS — comma-separated list of allowed frontend origins (set this in your deployment platform)
# Example: https://measora.io,https://www.measora.io,https://measora-staging.vercel.app
ALLOWED_ORIGINS="http://localhost:5173,http://localhost:3000"

# Base URL of the frontend (used for shareable result links)
FRONTEND_BASE_URL="https://measora.io"

# Measurement tuning
SCALE_MISMATCH_THRESHOLD=0.03
SCALE_MISMATCH_PENALTY_MULTIPLIER=1.5
